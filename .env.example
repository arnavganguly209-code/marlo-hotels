# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://marlohotels.com

# PostgreSQL connection string (Prisma)
# Example: postgresql://marlo:password@localhost:5432/marlo_hotels?schema=public
DATABASE_URL=

# Orbit administration (server-only — never prefix these with NEXT_PUBLIC_)
ORBIT_ADMIN_PASSKEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ORBIT_SESSION_SECRET=

# Optional persistent media path on the VPS.
# Default: <project>/public/uploads
ORBIT_UPLOAD_DIR=
