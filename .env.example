# Public site URL (used for canonical URLs, sitemap, OpenGraph, Secure cookies)
# Production MUST be https://your-domain — cookies and auth depend on this.
NEXT_PUBLIC_SITE_URL=https://marlo.theglobalorbit.com

# PostgreSQL connection string (Prisma) — required for CMS metrics/content,
# NOT required for Orbit login itself.
# Example: postgresql://marlo:password@localhost:5432/marlo_hotels?schema=public
DATABASE_URL=

# Orbit administration (server-only — never prefix these with NEXT_PUBLIC_)
# Both must be present in the PM2 / systemd runtime environment.
ORBIT_ADMIN_PASSKEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ORBIT_SESSION_SECRET=

# Persistent media path on the VPS (required in production).
# Local default: <project>/public/media
# Production example: /srv/marlo-media
ORBIT_UPLOAD_DIR=

# Optional upload limits (bytes). Defaults: images 25MB, videos 120MB.
ORBIT_MAX_IMAGE_BYTES=26214400
ORBIT_MAX_VIDEO_BYTES=125829120
